# Variables de entorno - Copia a .env y completa con tus valores

# APIs y Servicios Externos
VITE_API_URL=http://localhost:3000
VITE_STRIPE_PUBLIC_KEY=pk_test_your_key_here

# Analytics (opcional)
VITE_GOOGLE_ANALYTICS_ID=G_XXXXXXXXXX

# Contacto / Formularios
VITE_CONTACT_EMAIL=contacto@dscoach.com
VITE_SUPPORT_EMAIL=soporte@dscoach.com

# URLs Sociales
VITE_LINKEDIN_URL=https://linkedin.com/company/dscoach
VITE_TWITTER_URL=https://twitter.com/dscoach
VITE_INSTAGRAM_URL=https://instagram.com/dscoach

# Modo de desarrollo
VITE_ENV=development
